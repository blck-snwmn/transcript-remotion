{
  "name": "transcript-remotion",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render": "bun run scripts/render.ts",
    "transcribe": "bun run scripts/transcribe.ts",
    "typecheck": "tsc --noEmit",
    "build": "remotion bundle src/index.ts",
    "lint": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --deny-warnings . --fix",
    "fmt": "oxfmt --write src/ scripts/",
    "fmt:check": "oxfmt --check src/ scripts/"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "1.3.14",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "typescript": "7.0.2"
  },
  "peerDependencies": {
    "typescript": "^7.0.0"
  },
  "dependencies": {
    "@google/genai": "^2.0.0",
    "@remotion/captions": "4.0.491",
    "@remotion/cli": "4.0.491",
    "@remotion/media": "4.0.491",
    "@types/react": "^19.2.13",
    "mediabunny": "1.50.8",
    "openai": "^6.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "4.0.491",
    "zod": "4.3.6"
  }
}
